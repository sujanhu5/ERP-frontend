# In development, Vite's dev server proxies /api and /uploads to the backend
# (see vite.config.js), so no env var is needed locally.
#
# In production (e.g. deployed to Vercel), set this to your deployed backend URL
# and update src/services/api.js baseURL accordingly, or configure a rewrite/proxy
# on your hosting provider.
VITE_API_BASE_URL=https://your-backend.onrender.com/api
